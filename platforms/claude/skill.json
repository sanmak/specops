{
  "name": "specops",
  "version": "1.0.0",
  "description": "Spec-driven development workflow - create requirements, design, and implement with autonomous AI agent",
  "author": "SpecOps Contributors",
  "commands": [
    {
      "name": "specops",
      "description": "Launch SpecOps spec-driven development agent",
      "usage": "/specops [mode] [description]",
      "examples": [
        "/specops",
        "/specops spec Add user authentication",
        "/specops implement auth-feature",
        "/specops bugfix Users seeing 500 on checkout"
      ]
    }
  ],
  "configuration": {
    "configFile": ".specops.json",
    "schema": {
      "specsDir": {
        "type": "string",
        "default": ".specops",
        "description": "Directory to store specification files. Must be a relative path within the project.",
        "pattern": "^(?!.*\\.\\./)[a-zA-Z0-9._][a-zA-Z0-9._/-]*$",
        "maxLength": 200
      },
      "vertical": {
        "type": "string",
        "enum": [
          "backend",
          "frontend",
          "fullstack",
          "infrastructure",
          "data",
          "library"
        ],
        "description": "Project vertical that influences spec template adaptation. Auto-detected when not set."
      },
      "templates": {
        "type": "object",
        "properties": {
          "feature": {
            "type": "string",
            "default": "default",
            "maxLength": 100
          },
          "bugfix": {
            "type": "string",
            "default": "default",
            "maxLength": 100
          },
          "refactor": {
            "type": "string",
            "default": "default",
            "maxLength": 100
          },
          "design": {
            "type": "string",
            "default": "default",
            "maxLength": 100
          },
          "tasks": {
            "type": "string",
            "default": "default",
            "maxLength": 100
          }
        },
        "additionalProperties": false
      },
      "team": {
        "type": "object",
        "properties": {
          "conventions": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 500
            },
            "maxItems": 30,
            "description": "Team-specific conventions to follow"
          },
          "reviewRequired": {
            "type": "boolean",
            "default": false,
            "description": "Require review before implementation"
          },
          "taskTracking": {
            "type": "string",
            "enum": [
              "github",
              "jira",
              "linear",
              "none"
            ],
            "default": "none"
          },
          "taskPrefix": {
            "type": "string",
            "maxLength": 20,
            "description": "Optional task/ticket prefix for external trackers"
          },
          "codeReview": {
            "type": "object",
            "description": "Code review requirements",
            "properties": {
              "required": {
                "type": "boolean",
                "default": false
              },
              "minApprovals": {
                "type": "integer",
                "minimum": 1,
                "default": 1
              },
              "requireTests": {
                "type": "boolean",
                "default": true
              },
              "requireDocs": {
                "type": "boolean",
                "default": false
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "implementation": {
        "type": "object",
        "properties": {
          "autoCommit": {
            "type": "boolean",
            "default": false,
            "description": "Automatically commit after completing tasks"
          },
          "createPR": {
            "type": "boolean",
            "default": false,
            "description": "Automatically create PR when implementation is complete"
          },
          "testing": {
            "type": "string",
            "enum": [
              "auto",
              "manual",
              "skip"
            ],
            "default": "auto",
            "description": "Testing strategy"
          },
          "testFramework": {
            "type": "string",
            "maxLength": 50,
            "description": "Preferred test framework (jest, mocha, pytest, etc.)"
          },
          "linting": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "fixOnSave": {
                "type": "boolean",
                "default": false
              }
            },
            "additionalProperties": false
          },
          "formatting": {
            "type": "object",
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "tool": {
                "type": "string",
                "enum": [
                  "prettier",
                  "black",
                  "rustfmt",
                  "gofmt"
                ],
                "description": "Formatting tool to use"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "modules": {
        "type": "object",
        "description": "Module-specific configuration for monorepo/multi-module projects",
        "patternProperties": {
          "^[a-zA-Z0-9_-]+$": {
            "type": "object",
            "properties": {
              "specsDir": {
                "type": "string",
                "maxLength": 200,
                "pattern": "^(?!.*\\.\\./)[a-zA-Z0-9._][a-zA-Z0-9._/-]*$",
                "description": "Specs directory for this module"
              },
              "conventions": {
                "type": "array",
                "items": {
                  "type": "string",
                  "maxLength": 500
                },
                "maxItems": 30,
                "description": "Module-specific conventions"
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      },
      "integrations": {
        "type": "object",
        "description": "External tool integrations",
        "properties": {
          "ci": {
            "type": "string",
            "maxLength": 50,
            "description": "CI system (github-actions, gitlab-ci, jenkins, etc.)"
          },
          "deployment": {
            "type": "string",
            "maxLength": 50,
            "description": "Deployment platform (vercel, netlify, aws, etc.)"
          },
          "monitoring": {
            "type": "string",
            "maxLength": 50,
            "description": "Monitoring service (sentry, datadog, newrelic, etc.)"
          },
          "analytics": {
            "type": "string",
            "maxLength": 50,
            "description": "Analytics service (mixpanel, amplitude, etc.)"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "capabilities": [
    "Autonomous spec generation from natural language",
    "Interactive requirement refinement",
    "Technical design with sequence diagrams",
    "Task-based implementation planning",
    "Progress tracking and updates",
    "Team collaboration support",
    "Code review workflow management",
    "Linting and formatting configuration",
    "Module-specific configuration for monorepos",
    "External tool integrations (CI/CD, deployment, monitoring)",
    "Vertical-aware spec generation (backend, frontend, fullstack, infrastructure, data, library)"
  ]
}
