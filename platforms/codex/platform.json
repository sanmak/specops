{
  "name": "codex",
  "displayName": "OpenAI Codex",
  "version": "1.0.0",
  "instructionFormat": "agents_md",
  "outputFiles": {
    "agents": "AGENTS.md"
  },
  "installLocation": {
    "project": "AGENTS.md"
  },
  "capabilities": {
    "canExecuteCode": true,
    "canEditFiles": true,
    "canCreateFiles": true,
    "canAskInteractive": false,
    "canTrackProgress": false,
    "canAccessGit": true
  },
  "toolMapping": {
    "READ_FILE": "Read the file at",
    "WRITE_FILE": "Write the file at",
    "EDIT_FILE": "Edit the file at",
    "LIST_DIR": "List the directory at",
    "RUN_COMMAND": "Execute the command",
    "ASK_USER": "If uncertain, note assumptions in the spec and proceed. List any ambiguities for the user to review",
    "NOTIFY_USER": "Print to stdout",
    "UPDATE_PROGRESS": "Print progress to stdout"
  },
  "entryPoint": {
    "type": "keyword",
    "trigger": "When the user asks you to run 'specops', mentions 'spec-driven development', or asks you to 'create a spec' for a feature, bugfix, or refactor"
  }
}
